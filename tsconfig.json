{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["chrome"],

        "strict": true,
        "skipLibCheck": true,

        "sourceMap": true,
        "declaration": false,
        "declarationMap": false
    },
    "include": ["src/**/*.ts"]
}
