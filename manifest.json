{
    "manifest_version": 3,
    "name": "Sir Tab",
    "version": "1.0.0",
    "description": "Tab manager that helps you organise and manage your tabs efficiently.",
    "action": {
        "default_title": "Open Sir Tab"
    },
    "side_panel": {
        "default_path": "sidebar/sidebar.html"
    },
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "permissions": ["tabs", "tabGroups", "storage", "sidePanel", "bookmarks"],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            }
        },
        "cycle_next_visible_tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+J",
                "mac": "Alt+Period"
            },
            "description": "Switch to the next visible tab in sidebar order"
        },
        "cycle_previous_visible_tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+K",
                "mac": "Alt+Comma"
            },
            "description": "Switch to the previous visible tab in sidebar order"
        }
    }
}
