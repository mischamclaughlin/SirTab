{
    "manifest_version": 3,
    "name": "Sir Tab",
    "version": "1.0.0",
    "description": "Tab manager that helps you organise and manage your tabs efficiently.",
    "action": {
        "default_title": "Open Sir Tab"
    },
    "side_panel": {
        "default_path": "src/sidebar/sidebar.html"
    },
    "background": {
        "service_worker": "dist/background/background.js",
        "type": "module"
    },
    "permissions": ["tabs", "tabGroups", "storage", "sidePanel", "bookmarks"],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+L",
                "mac": "Command+Shift+L"
            }
        }
    }
}
