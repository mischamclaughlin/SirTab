{
    "manifest_version": 3,
    "name": "Sir Tab",
    "version": "1.0.0",
    "minimum_chrome_version": "141",
    "description": "Tab manager that helps you organise and manage your tabs efficiently.",
    "action": {
        "default_icon": {
            "16": "sidebar/assets/sir-tab-icon-16.png",
            "32": "sidebar/assets/sir-tab-icon-32.png"
        },
        "default_title": "Open Sir Tab"
    },
    "icons": {
        "16": "sidebar/assets/sir-tab-icon-16.png",
        "32": "sidebar/assets/sir-tab-icon-32.png",
        "48": "sidebar/assets/sir-tab-icon-48.png",
        "128": "sidebar/assets/sir-tab-icon-128.png"
    },
    "side_panel": {
        "default_path": "sidebar/sidebar.html"
    },
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "permissions": [
        "tabs",
        "tabGroups",
        "storage",
        "sidePanel",
        "bookmarks"
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            }
        },
        "cycle_next_visible_tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+J",
                "mac": "Alt+Period"
            },
            "description": "Switch to the next visible tab in sidebar order"
        },
        "cycle_previous_visible_tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+K",
                "mac": "Alt+Comma"
            },
            "description": "Switch to the previous visible tab in sidebar order"
        },
        "move_active_tab_next": {
            "description": "Move tab down"
        },
        "move_active_tab_previous": {
            "description": "Move tab up"
        }
    }
}
